{
  "manifest_version": 3,
  "name": "Lexis Web",
  "version": "1.0.5",
  "description": "在任意网页高亮你 Obsidian Lexis 词库里的单词、悬停看释义。与本机的 Lexis 桥接通信,数据不出本机。",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lexis Web"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
